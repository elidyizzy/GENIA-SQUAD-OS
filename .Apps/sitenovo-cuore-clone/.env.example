# ──────────────────────────────────────────────────────────
# Cuore Terapia Verde — Variáveis de Ambiente
# Copie este arquivo para .env e preencha os valores reais
# ──────────────────────────────────────────────────────────

# Servidor
PORT=3001
NODE_ENV=development

# JWT — gere um segredo forte (ex: openssl rand -base64 32)
JWT_SECRET=troque-por-um-segredo-forte

# Credenciais do painel admin
ADMIN_EMAIL=admin@cuoreterapiaverde.com.br
ADMIN_PASSWORD=troque-por-senha-forte

# Caminhos de persistência (em produção Railway, aponta para o volume montado)
# DATABASE_PATH=/data/cuore.db
# UPLOADS_DIR=/data/uploads
